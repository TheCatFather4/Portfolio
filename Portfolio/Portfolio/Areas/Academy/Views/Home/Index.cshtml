@{
    Layout = "_AcademyLayout";
    ViewData["Title"] = "4th Wall Academy";
}


@if (User.Identity.IsAuthenticated)
{
    <div class="text-center">
        <h3 class="mt-3 text-info">Account Dashboard</h3>
    </div>
    <div class="text-center my-3">
        <a asp-area="Academy" asp-controller="Admissions" asp-action="Index">Admissions Area (An Admissions account is required)</a>
    </div>
    <div class="text-center my-3">
        <a asp-area="Academy" asp-controller="Student" asp-action="Index">Student Area (An Student account is required)</a>
    </div>
}
else
{
    <div class="text-center my-3">
        <h1 style="color:crimson">Welcome to the 4th Wall Academy</h1>
        <h3 class="text-info">THE premier university for aspiring superheroes!</h3>
    </div>
    <div>
        <p class="text-center" id="academy-text">Please log in using the navbar above.</p>
    </div>
}